{
  "name": "xca-agent",
  "version": "0.1.0",
  "description": "A cross-platform, flexible LLM agent similar to Claude Code",
  "main": "dist/index.js",
  "bin": {
    "xca": "bin/xca"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest",
    "lint": "eslint src/**/*.ts",
    "package": "pkg dist/index.js --targets node18-macos-arm64 --output bin/xca"
  },
  "keywords": [
    "ai",
    "agent",
    "claude-code",
    "ollama",
    "llm",
    "cli"
  ],
  "author": "xca",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "inquirer": "^9.2.0",
    "ora": "^8.0.0",
    "zod": "^3.22.0",
    "globby": "^14.0.0",
    "execa": "^8.0.0",
    "diff": "^5.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/inquirer": "^9.0.0",
    "@types/diff": "^5.0.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "vitest": "^1.3.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "pkg": "^5.8.0"
  }
}
